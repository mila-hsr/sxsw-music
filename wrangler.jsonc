{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sxsw-music",
  "main": "worker/index.js",
  "compatibility_date": "2026-03-01",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
